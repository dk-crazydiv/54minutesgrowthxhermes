+    unaffected) and None when no scope is resolvable (falls back to the global
+    shared session -- the historical behavior).
+    """
+    if server_name not in _SCOPED_MCP_SERVERS:
+        return None
+    # 1. Explicit override.
+    try:
+        from hermes_constants import get_credential_scope
+        override = get_credential_scope()
+        if override:
+            return override
+    except Exception:
+        pass
+    # 2. Gateway session user id (the inbound Telegram user).
+    try:
+        from gateway.session_context import get_session_env
+        uid = get_session_env("HERMES_SESSION_USER_ID", "")
+        if uid:
+            return str(uid)
+    except Exception:
+        pass
+    return None
+
