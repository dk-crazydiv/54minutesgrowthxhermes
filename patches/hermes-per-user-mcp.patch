+def _lazy_connect_scoped_session(
+    server_name: str, scope: str, registry_key: str
+) -> Optional[MCPServerTask]:
+    """Connect (once) a per-scope MCPServerTask for a scoped server.
+
+    Reuses the *global* server's connection config (transport, url, oauth
+    config) and only overrides the OAuth credential scope, so the scoped
+    session authenticates with the per-user token store. The result is cached
+    in ``_servers`` under ``registry_key`` so subsequent calls for the same
+    user reuse the live session. Returns None if no base config is available
+    or the connect fails.
+    """
+    with _lock:
+        base = _servers.get(server_name)
+        already = _servers.get(registry_key)
+    if already is not None:
+        return already
