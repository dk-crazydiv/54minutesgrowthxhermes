+# Servers that participate in per-Telegram-user credential isolation. Only
+# these get a per-scope session; every other MCP server keeps the historical
+# single global session and token file. Deliberately narrow (Zomato only) so
+# the blast radius of this feature is one server.
+_SCOPED_MCP_SERVERS: frozenset = frozenset({"zomato"})
+
+# Sentinel separating server name from scope in a composite registry key.
+# NUL can never appear in a sanitized server/scope name, so it can't collide
+# with a legitimately-named unscoped server.
+_SCOPE_KEY_SEP = "\x00"
+
+
+def _server_registry_key(server_name: str, scope: Optional[str]) -> str:
+    """Return the ``_servers`` dict key for a (server, scope) pair.
+
+    Unscoped (or a server not in ``_SCOPED_MCP_SERVERS``) returns the bare
+    ``server_name`` so existing global sessions are keyed exactly as before.
+    A scope on a scoped server yields ``"<server>\\x00<scope>"``.
+    """
+    if scope and server_name in _SCOPED_MCP_SERVERS:
+        return f"{server_name}{_SCOPE_KEY_SEP}{scope}"
+    return server_name
+
+
+def _active_scope_for(server_name: str) -> Optional[str]:
+    """Return the credential scope that should apply to ``server_name`` now.
+
+    Resolution order (first non-empty wins):
+
+    1. An explicit context-local credential scope set via
+       ``hermes_constants.set_credential_scope`` -- an override channel used by
+       tests and any caller that wants to force a specific scope.
+    2. The current gateway session's Telegram user id
+       (``HERMES_SESSION_USER_ID``). The gateway already binds this per inbound
+       message via ``gateway.session_context.set_session_vars`` and propagates
+       it onto agent/executor threads, so at MCP-tool-call time (which runs on
+       the agent thread) it uniquely identifies the requesting Telegram user.
+
