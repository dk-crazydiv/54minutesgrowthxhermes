+# ---------------------------------------------------------------------------
+# Per-user credential scope (Hermes per-Telegram-user MCP isolation)
+#
+# This mirrors the HERMES_HOME override channel above but carries a
+# *credential scope* -- an opaque per-user tag (e.g. a Telegram user id)
+# used to select a per-user MCP OAuth session and token file so two users
+# messaging the bot at the same time each transact on their own upstream
+# account (see docs/hermes/per-user-isolation.md). It is deliberately a
+# separate ContextVar: home-override reroutes the *whole* profile home,
+# whereas credential scope only redirects a single scoped MCP server
+# (currently "zomato") while leaving every other server global.
+# ---------------------------------------------------------------------------
+_CREDENTIAL_SCOPE: ContextVar[str | object] = ContextVar(
+    "_CREDENTIAL_SCOPE", default=_UNSET
+)
+
+
+def set_credential_scope(scope: str | None) -> Token:
+    """Set the context-local per-user credential scope; return a reset token.
+
+    In-process, per-task scoping only -- never mutates ``os.environ`` (which
+    is shared across threads). Pass ``None`` to clear.
+    """
+    value: str | object = _UNSET if not scope else str(scope)
+    return _CREDENTIAL_SCOPE.set(value)
+
+
+def reset_credential_scope(token: Token) -> None:
+    """Restore the previous context-local credential scope."""
+    _CREDENTIAL_SCOPE.reset(token)
+
+
+def get_credential_scope() -> str | None:
+    """Return the active context-local credential scope, if any."""
+    scope = _CREDENTIAL_SCOPE.get()
+    if scope is _UNSET or not scope:
+        return None
+    return str(scope)
+
+
