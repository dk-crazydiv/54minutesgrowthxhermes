{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "Skill",
      "Artifact"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Read(.env)",
      "Read(**/auth.json)"
    ]
  }
}
