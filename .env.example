# Hermes Agent config — food-buildathon.
#
# These are placeholder names; the real values live in the opencode auth
# store on this host. See the project README ("Secrets" section) for the
# copy-from-auth-store recipe. Never commit real values here.
#
# Two model endpoints back the agent:
#   - glm     → the "thinking" brain (Z.AI / ZhipuAI)
#   - minimax → the "chatty" brain (MiniMax)
#
# Hermes auto-detects the right base URL for each key when GLM_BASE_URL /
# MINIMAX_BASE_URL are unset; the defaults route to the global endpoints.
# If you have a "Coding Plan" key on Z.AI, set GLM_BASE_URL to the matching
# coding endpoint (see hermes's `model_setup_flows.py` for the list).
GLM_API_KEY=
MINIMAX_API_KEY=

# Optional: override the default base URLs (see README).
# GLM_BASE_URL=https://api.z.ai/api/paas/v4
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# ----------------------------------------------------------------------------
# Telegram gateway — the bot the human messages.
# ----------------------------------------------------------------------------
# The bot token comes from @BotFather. Steps (see README "Telegram gateway"):
#   1. Open https://t.me/BotFather and send /newbot
#   2. Pick a display name (e.g. "Food Copilot") and a username ending in `bot`
#   3. Copy the API token BotFather replies with — it looks like
#      123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram user IDs allowed to talk to the bot.
# Find yours by messaging @userinfobot (it replies with your number).
# This is a numeric ID, NOT your @username. Example: TELEGRAM_ALLOWED_USERS=123456789
TELEGRAM_ALLOWED_USERS=

# Optional: the chat/channel ID where cron jobs and notifications land.
# Set it later from any chat with /sethome, or paste a group ID here (negative).
# TELEGRAM_HOME_CHANNEL=-1001234567890
